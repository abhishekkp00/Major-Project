# ==============================================================================
# SECURE DEVICE-BOUND LORA FINE-TUNING FRAMEWORK - CONFIGURATION
# ==============================================================================

# Cryptographic Key Configuration (Provide ONE of these)
# ------------------------------------------------------------------------------
# Option A: A hex-encoded 32-byte (256-bit) key (64 hex characters)
SECURE_LORA_KEY_HEX=

# Option B: Path to the key file on disk
SECURE_LORA_KEY_PATH=secrets.key

# Pipeline Parameter Defaults
# ------------------------------------------------------------------------------
SECURE_LORA_INPUT_DIR=real_data_inputs
SECURE_LORA_OUTPUT_DIR=encrypted_real_data
SECURE_LORA_DATASET_NAME=CorporateDataset
SECURE_LORA_DATASET_VERSION=1.0.0
