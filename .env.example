# ==============================================================================
# SECURE DEVICE-BOUND LORA FINE-TUNING FRAMEWORK - CONFIGURATION
# ==============================================================================

# Cryptographic Key Configuration (Provide ONE of these)
# ------------------------------------------------------------------------------
# Option A: A hex-encoded 32-byte (256-bit) key (64 hex characters)
SECURE_LORA_KEY_HEX=

# Option B: Path to the key file on disk
SECURE_LORA_KEY_PATH=secrets.key

# Pipeline Parameter Defaults
# ------------------------------------------------------------------------------
SECURE_LORA_INPUT_DIR=real_data_inputs
SECURE_LORA_OUTPUT_DIR=encrypted_real_data
SECURE_LORA_DATASET_NAME=CorporateDataset
SECURE_LORA_DATASET_VERSION=1.0.0

# ==============================================================================
# PHASE 3: Adapter Protection and Device Binding
# ==============================================================================

# REQUIRED: Secret salt for device-bound AES key derivation.
# Generate a strong random value, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
# Never commit the actual value to version control.
P3_DEVICE_SALT=

# Phase 2 adapter output directory (default: outputs/final_adapter)
P3_ADAPTER_INPUT_DIR=outputs/final_adapter

# Phase 3 protected package output directory (default: outputs/protected_adapter)
P3_PROTECTED_OUTPUT_DIR=outputs/protected_adapter

# RSA key size in bits for dev/test keypair generation (default: 2048)
P3_RSA_KEY_BITS=2048

# Path for the dev/test RSA private key (never commit to git)
P3_RSA_PRIVATE_KEY_PATH=outputs/protected_adapter/dev_private.pem

# Path for the RSA public key (included in the deployable package)
P3_RSA_PUBLIC_KEY_PATH=outputs/protected_adapter/public.pem

# Human-readable adapter identifier embedded in the package manifest
P3_ADAPTER_ID=lora-adapter-v1

# Base model this adapter was trained on (informational)
P3_MODEL_REFERENCE=JackFram/llama-68m
